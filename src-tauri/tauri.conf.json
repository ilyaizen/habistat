{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Habistat",
  "version": "0.0.0",
  "identifier": "com.habistat.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:3001",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Habistat",
        "width": 800,
        "height": 600,
        "additionalBrowserArgs": "--enable-smooth-scrolling"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "os": {},
    "opener": {}
  },
  "allowlist": {
    "all": false,
    "http": {
      "all": false,
      "scope": [
        "https://clerk.*.clerk.accounts.dev/*",
        "http://localhost:3001/*",
        "https://frugal-flamingo-585.convex.cloud/*"
      ],
      "unsafeFetch": {
        "all": false,
        "scope": []
      }
    },
    "os": {
      "all": false,
      "type": true
    },
    "shell": {
      "all": false,
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}