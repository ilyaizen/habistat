{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Habistat",
  "version": "0.0.0",
  "identifier": "com.habistat.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:3001",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Habistat",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}